# Required in production for canonical URLs and sitemap generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional until booking flow is live (fallback routes to /book)
# NEXT_PUBLIC_BOOKING_URL=https://calendly.com/your-handle/discovery

# Optional analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=twoapps.example

# Optional GSC verification meta
# NEXT_PUBLIC_GSC_VERIFICATION=your-google-site-verification-token

# Contact form (required for production email sending)
# RESEND_API_KEY=re_xxx
# CONTACT_TO_EMAIL=hello@twoapps.example
# CONTACT_FROM_EMAIL=Two Apps <hello@twoapps.example>

