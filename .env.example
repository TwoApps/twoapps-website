# Required in production for canonical URLs and sitemap generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Calendly booking URL
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/team-thetwoapps/30min

# Optional: Contact phone number (displayed on contact page)
# NEXT_PUBLIC_CONTACT_PHONE="+971 55 672 7803"

# Optional analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=twoapps.example

# Optional GSC verification meta
# NEXT_PUBLIC_GSC_VERIFICATION=your-google-site-verification-token

# Email configuration (required for production email sending)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=team@twoapps.com
CONTACT_FROM_EMAIL=TwoApps <team@twoapps.com>

# Cron job authentication (required for nurture email automation)
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-here
